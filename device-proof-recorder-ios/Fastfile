# Fastfile for DIGM ◉rigins iOS App
# Documentation: https://docs.fastlane.tools

default_platform(:ios)

platform :ios do
  # Variables
  PROJECT_NAME = "🅞rigins"
  SCHEME = "DIGM_Origins"
  APP_IDENTIFIER = "org.usexfg.digmorigins"
  APP_NAME = "DIGM ◉rigins"

  before_all do
    # Ensure we have xcodegen
    setup_xcodegen
  end

  desc "Setup xcodegen for project generation"
  lane :setup_xcodegen do
    unless File.exist?("/tmp/xcodegen/bin/xcodegen")
      sh("curl -L https://github.com/yonaskolb/XcodeGen/releases/download/2.44.1/xcodegen.zip -o /tmp/xcodegen.zip")
      sh("unzip -q -o /tmp/xcodegen.zip -d /tmp/")
      sh("chmod +x /tmp/xcodegen/bin/xcodegen")
    end
  end

  desc "Generate Xcode project from project.yml"
  lane :generate_project do
    sh("/tmp/xcodegen/bin/xcodegen generate || which xcodegen && xcodegen generate")
  end

  desc "Run tests"
  lane :test do
    generate_project
    scan(
      project: "#{PROJECT_NAME}.xcodeproj",
      scheme: SCHEME,
      device: "iPhone 15",
      code_coverage: true
    )
  end

  desc "Build the app"
  lane :build do
    generate_project
    
    build_app(
      project: "#{PROJECT_NAME}.xcodeproj",
      scheme: SCHEME,
      configuration: "Debug",
      export_method: "development",
      output_directory: "./build",
      output_name: "#{APP_NAME}.ipa",
      skip_codesigning: true,
      skip_package_ipa: true
    )
  end

  desc "Build for simulator (no signing required)"
  lane :build_simulator do
    generate_project
    
    sh("xcodebuild clean build " \
       "-project '#{PROJECT_NAME}.xcodeproj' " \
       "-scheme '#{SCHEME}' " \
       "-configuration Debug " \
       "-sdk iphonesimulator " \
       "-destination 'platform=iOS Simulator,name=iPhone 15' " \
       "CODE_SIGN_IDENTITY='' " \
       "CODE_SIGNING_REQUIRED=NO " \
       "CODE_SIGNING_ALLOWED=NO")
  end

  desc "Build and archive for distribution"
  lane :archive do
    generate_project
    
    build_app(
      project: "#{PROJECT_NAME}.xcodeproj",
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      archive_path: "./build/#{APP_NAME}.xcarchive",
      output_directory: "./build",
      output_name: "#{APP_NAME}.ipa",
      include_bitcode: true,
      include_symbols: true
    )
  end

  desc "Upload to TestFlight (beta distribution)"
  lane :beta do
    archive
    
    upload_to_testflight(
      ipa: "./build/#{APP_NAME}.ipa",
      skip_waiting_for_build_processing: false,
      skip_submission: false,
      distribute_external: false,
      notify_external_testers: true,
      changelog: "#{changelog_from_git_commits}"
    )
    
    slack(
      message: "✅ Successfully uploaded #{APP_NAME} to TestFlight",
      success: true
    )
  rescue => e
    slack(
      message: "❌ Failed to upload #{APP_NAME} to TestFlight: #{e.message}",
      success: false
    )
    raise
  end

  desc "Release to App Store"
  lane :release do
    archive
    
    upload_to_app_store(
      ipa: "./build/#{APP_NAME}.ipa",
      force: true,
      submit_for_review: false,
      automatic_release: false,
      skip_metadata: false,
      skip_screenshots: false
    )
    
    slack(
      message: "🚀 Successfully submitted #{APP_NAME} to App Store",
      success: true
    )
  rescue => e
    slack(
      message: "❌ Failed to submit #{APP_NAME} to App Store: #{e.message}",
      success: false
    )
    raise
  end

  desc "Increment build number"
  lane :increment_build do
    increment_build_number(
      xcodeproj: "#{PROJECT_NAME}.xcodeproj"
    )
  end

  desc "Increment version number"
  lane :increment_version do
    increment_version_number(
      xcodeproj: "#{PROJECT_NAME}.xcodeproj",
      version_number: ENV["VERSION_NUMBER"] # e.g., "1.0.1"
    )
  end

  desc "Match certificates and provisioning profiles"
  lane :match do
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      readonly: true
    )
  end

  desc "Run fastlane from GitHub Actions"
  lane :ci do
    generate_project
    
    # Increment build number if needed
    if ENV["CI"] == "true"
      increment_build_number(
        xcodeproj: "#{PROJECT_NAME}.xcodeproj",
        build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
      )
    end
    
    build_simulator
    
    # Archive if it's a release
    if ENV["GITHUB_REF"] == "refs/heads/main" || ENV["GITHUB_REF"].include?("refs/tags/")
      archive
    end
  end

  desc "Clean build artifacts"
  lane :clean do
    sh("rm -rf ./build")
    sh("rm -rf ./DerivedData")
    sh("rm -rf ./*.xcarchive")
  end
end


